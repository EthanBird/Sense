<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="io.github.ethanbird.senseime"
    android:versionCode="12"
    android:versionName="0.3.5-m8">
    <uses-sdk
        android:minSdkVersion="29"
        android:targetSdkVersion="36" />

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@drawable/ic_sense"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sense">
        <activity
            android:name="io.github.ethanbird.senseime.SettingsActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name="io.github.ethanbird.senseime.service.SenseInputMethodService"
            android:directBootAware="false"
            android:exported="true"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:process=":ime">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>

            <meta-data
                android:name="android.view.im"
                android:resource="@xml/input_method" />
        </service>

        <service
            android:name="io.github.ethanbird.senseime.brain.runtime.SenseAiBrainService"
            android:directBootAware="false"
            android:exported="false"
            android:process=":brain" />
    </application>
</manifest>
